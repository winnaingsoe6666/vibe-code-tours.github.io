---
// Military-style rank insignia for chapter level (ch-0..ch-8).
// Tiers by metal: 0 steel · 1-3 silver (chevrons) · 4-6 gold+wings (stars) ·
// 7-8 amethyst+wings (stars). Pure SVG — scalable, themeable, no raster assets.
interface Props {
  level: number; // 0..8
  size?: number; // px, default 44
  title?: string;
}
const { level, size = 44, title } = Astro.props;
const lv = Math.max(0, Math.min(8, level));

// tier metals: gradient stops (bright/mid/edge/deep), inner panel, insignia ink
const TIERS = {
  steel: {
    hi: "#eef2f8",
    mid: "#8b95a4",
    edge: "#c2ccd9",
    deep: "#5c6675",
    panel: "#222b3a",
    ink: "#9aa4b3",
    rivet: "#d7dde6",
    wings: false,
  },
  silver: {
    hi: "#ffffff",
    mid: "#9fadbf",
    edge: "#d7e1ee",
    deep: "#6c7a8d",
    panel: "#1d2837",
    ink: "#e6eef9",
    rivet: "#f1f5fb",
    wings: false,
  },
  gold: {
    hi: "#fff3c4",
    mid: "#d4a428",
    edge: "#ffd968",
    deep: "#9a6e12",
    panel: "#173028",
    ink: "#fff0bd",
    rivet: "#ffe9ad",
    wings: true,
  },
  amethyst: {
    hi: "#f1e3ff",
    mid: "#8b4ff0",
    edge: "#c79bff",
    deep: "#5b27b5",
    panel: "#1f1338",
    ink: "#f0e2ff",
    rivet: "#ecdcff",
    wings: true,
  },
};
const tier =
  lv === 0
    ? TIERS.steel
    : lv <= 3
      ? TIERS.silver
      : lv <= 6
        ? TIERS.gold
        : TIERS.amethyst;

const chevrons = lv >= 1 && lv <= 3 ? lv : 0;
const stars = lv >= 4 ? (lv <= 6 ? lv - 3 : lv - 5) : 0; // 4-6 -> 1-3, 7-8 -> 2-3
const uid = `rb${lv}`;

function star(cx: number, cy: number, r: number) {
  const pts = [];
  for (let i = 0; i < 10; i++) {
    const ang = (Math.PI / 5) * i - Math.PI / 2;
    const rad = i % 2 === 0 ? r : r * 0.42;
    pts.push(
      `${(cx + rad * Math.cos(ang)).toFixed(1)},${(cy + rad * Math.sin(ang)).toFixed(1)}`,
    );
  }
  return "M" + pts.join("L") + "Z";
}
const starRow = (n: number, cy: number, r: number) => {
  const gap = r * 2.25;
  const x0 = 60 - ((n - 1) * gap) / 2;
  return Array.from({ length: n }, (_, i) => star(x0 + i * gap, cy, r));
};
const chevron = (i: number) => {
  const y = 49 + i * 13;
  return `M43 ${y} L60 ${y + 12} L77 ${y} L77 ${y + 7} L60 ${y + 19} L43 ${y + 7} Z`;
};
// rivet positions = shield vertices
const rivets = [
  [30, 25],
  [90, 25],
  [101, 64],
  [60, 106],
  [19, 64],
];
---

<svg
  width={size}
  height={size}
  viewBox="-10 4 140 122"
  role="img"
  aria-label={title ?? `Chapter ${lv} rank`}
  class="rank-badge"
>
  {title && <title>{title}</title>}
  <defs>
    <linearGradient id={`${uid}f`} x1="0.2" y1="0" x2="0.8" y2="1">
      <stop offset="0" stop-color={tier.hi}></stop>
      <stop offset="0.42" stop-color={tier.mid}></stop>
      <stop offset="0.62" stop-color={tier.deep}></stop>
      <stop offset="1" stop-color={tier.edge}></stop>
    </linearGradient>
    <linearGradient id={`${uid}p`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color={tier.panel}></stop>
      <stop offset="1" stop-color="#080b12"></stop>
    </linearGradient>
    <linearGradient id={`${uid}w`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color={tier.hi}></stop>
      <stop offset="1" stop-color={tier.mid}></stop>
    </linearGradient>
    <radialGradient id={`${uid}r`} cx="0.35" cy="0.3" r="0.8">
      <stop offset="0" stop-color={tier.rivet}></stop>
      <stop offset="1" stop-color={tier.deep}></stop>
    </radialGradient>
  </defs>

  {/* wings (gold/amethyst) — layered feathers, mirrored */}
  {
    tier.wings && (
      <g>
        <g
          id={`${uid}wing`}
          fill={`url(#${uid}w)`}
          stroke="#00000022"
          stroke-width="0.6"
        >
          <path d="M60 28 C82 17 104 17 124 24 C104 24 96 28 84 35 C74 30 66 30 60 33 Z" />
          <path
            d="M60 35 C78 27 96 27 112 33 C96 32 90 35 80 41 C72 37 66 37 60 39 Z"
            opacity="0.92"
          />
          <path
            d="M60 42 C74 36 88 36 100 41 C88 41 84 43 76 47 C70 44 65 44 60 45 Z"
            opacity="0.85"
          />
        </g>
        <use href={`#${uid}wing`} transform="matrix(-1 0 0 1 120 0)" />
      </g>
    )
  }

  {/* outer shield frame */}
  <path
    d="M30 25 L90 25 L101 64 L60 106 L19 64 Z"
    fill={`url(#${uid}f)`}
    stroke="#00000040"
    stroke-width="2"
    stroke-linejoin="round"></path>
  {/* bevel rim */}
  <path
    d="M35 30 L85 30 L94 63 L60 99 L26 63 Z"
    fill="none"
    stroke={tier.hi}
    stroke-opacity="0.5"
    stroke-width="1.2"
    stroke-linejoin="round"></path>
  {/* inner panel */}
  <path
    d="M38 33 L82 33 L92 64 L60 96 L28 64 Z"
    fill={`url(#${uid}p)`}
    stroke="#00000055"
    stroke-width="1"></path>

  {/* insignia */}
  <g fill={tier.ink} stroke="#00000033" stroke-width="0.5">
    {
      chevrons > 0 &&
        Array.from({ length: chevrons }, (_, i) => <path d={chevron(i)} />)
    }
    {stars > 0 && starRow(stars, 64, 12).map((d) => <path d={d} />)}
  </g>

  {/* rivets */}
  {
    rivets.map(([x, y]) => (
      <circle
        cx={x}
        cy={y}
        r="2.6"
        fill={`url(#${uid}r)`}
        stroke="#00000044"
        stroke-width="0.5"
      />
    ))
  }

  {/* top gloss */}
  <path d="M33 28 L87 28 L80 37 L40 37 Z" fill="#ffffff" opacity="0.22"></path>
</svg>
